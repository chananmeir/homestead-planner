# Security Configuration
# IMPORTANT: Generate a secure random secret key for production
# You can generate one with: python -c "import os; print(os.urandom(24).hex())"
# This key is used to sign session cookies and must be kept secret!
SECRET_KEY=your-secure-random-secret-key-here

# Geocoding API Configuration
# Sign up for Geocodio at https://www.geocod.io/ (free tier: 2,500 requests/day)
# Or use Google Maps Geocoding API at https://developers.google.com/maps/documentation/geocoding

# Choose your provider: 'geocodio' or 'google'
GEOCODING_PROVIDER=geocodio

# Your API key (get from your provider's dashboard)
GEOCODING_API_KEY=your_api_key_here

# Weather API Configuration
# Sign up for WeatherAPI.com at https://www.weatherapi.com/signup.aspx (free tier: 1M calls/month)
WEATHER_API_KEY=your_weatherapi_key_here

# USDA FoodData Central API Configuration
# Sign up for USDA FoodData Central at https://fdc.nal.usda.gov/api-key-signup.html (free, 1,000 requests/hour)
# Used for importing nutritional data for crops
USDA_API_KEY=your_usda_api_key_here

# Instructions:
# 1. Copy this file to .env (don't commit .env to git!)
# 2. Sign up for Geocodio (free): https://www.geocod.io/
# 3. Sign up for WeatherAPI.com (free): https://www.weatherapi.com/signup.aspx
# 4. Sign up for USDA FoodData Central (free): https://fdc.nal.usda.gov/api-key-signup.html
# 5. Get your API keys from their respective dashboards
# 6. Replace 'your_api_key_here' placeholders with your actual API keys
# 7. Restart your Flask server
