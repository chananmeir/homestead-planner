# Homestead Planner - Environment Configuration Template
#
# Copy this file to .env.local to customize your local environment
# IMPORTANT: Restart the development server after changing environment variables

# ==============================================================================
# API Configuration
# ==============================================================================

# Backend API Base URL
# Default: http://localhost:5000 (used if not specified)
#
# Examples:
# - Local development (default): http://localhost:5000
# - Local backend on different port: http://localhost:8080
# - Remote development backend: https://api-dev.example.com
# - Staging backend: https://api-staging.example.com
# - Production backend: https://api.example.com
#
REACT_APP_API_URL=http://localhost:5000

# ==============================================================================
# Notes
# ==============================================================================
#
# - All React environment variables must start with REACT_APP_
# - Changes to .env files require restarting the dev server (npm start)
# - .env.local is gitignored - use it for your local overrides
# - .env.example is committed - use it as a template
#
# ==============================================================================
